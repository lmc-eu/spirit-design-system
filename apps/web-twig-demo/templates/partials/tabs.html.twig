{% set currentRoute = app.request.get('_route') %}

{% set pages = {
  'index': 'Components',
  'icons_index': 'Icons',
  'helpers_index': 'Helpers',
  'validations_index': 'Validations',
} %}

<TabList>
  {% for route, title in pages %}
    {% set _isSelected = currentRoute == route %}
    <TabItem>
      <TabLink href="{{ path(route) }}" isSelected={{ _isSelected }}>
        {{ title }}
      </TabLink>
    </TabItem>
  {% endfor %}
</TabList>
