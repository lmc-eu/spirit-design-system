      </Button>
    {% endif %}
  </HeaderMobileActions>

  <HeaderDesktopActions>
    <HeaderNav>
      {% for title, url in sections %}
        {% set _isCurrent = title == currentTitle %}
        {% set _offsetClassName = title starts with 'Form Validations' ? 'ml-700' : null %}
        <HeaderNavItem>
          <HeaderLink href="{{ url }}" isCurrent="{{ _isCurrent }}" UNSAFE_className="{{ _offsetClassName }}">
            {{ title }}
          </HeaderLink>
        </HeaderNavItem>
      {% endfor %}
    </HeaderNav>
  </HeaderDesktopActions>

  <HeaderDesktopActions color="secondary">
    <ButtonLink href="https://spirit.supernova-docs.io/spirit/" size="large">
      Spirit Docs →
    </ButtonLink>
    <ButtonLink
      href="https://github.com/lmc-eu/spirit-design-system"
      color="inverted"
      size="large"
    >
      GitHub Project
    </ButtonLink>
  </HeaderDesktopActions>

</Header>

<HeaderDialog id="main-menu-dialog">
  <HeaderDialogCloseButton dialogId="main-menu-dialog" />
  <HeaderDialogActions>
    <HeaderDialogNav>
      {% for title, url in sections %}
        {% set _isCurrent = title == currentTitle %}
        {% set _offsetClassName = title starts with 'Form Validations' ? 'mt-700' : null %}
        <HeaderDialogNavItem>
          <HeaderDialogLink href="{{ url }}" isCurrent="{{ _isCurrent }}" UNSAFE_className="{{ _offsetClassName }}">
            {{ title }}
          </HeaderDialogLink>
        </HeaderDialogNavItem>
      {% endfor %}
    </HeaderDialogNav>
  </HeaderDialogActions>
  <HeaderDialogActions color="secondary">
    <ButtonLink href="https://spirit.supernova-docs.io/spirit/">
      Spirit Docs →
    </ButtonLink>
    <ButtonLink href="https://github.com/lmc-eu/spirit-design-system" color="inverted">
      GitHub Project
    </ButtonLink>
  </HeaderDialogActions>
</HeaderDialog>

{% if app.request.get('_route') != 'index' %}
  <HeaderDialog id="components-menu-dialog">
    <HeaderDialogCloseButton dialogId="components-menu-dialog" />
    <HeaderDialogActions>
      <HeaderDialogNav>
        {% for component in components %}
          <HeaderDialogNavItem>
            <HeaderDialogLink href="{{ '/components/' ~ component | lower ~ '/' }}">
              {{ component }}
            </HeaderDialogLink>
          </HeaderDialogNavItem>
        {% endfor %}
      </HeaderDialogNav>
    </HeaderDialogActions>
  </HeaderDialog>
{% endif %}
