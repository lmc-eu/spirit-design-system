{# API #}
{%- set props = props | default([]) -%}
{%- set _elementType = props.elementType -%}
{%- set _emphasis = props.emphasis | default('bold') -%}
{%- set _size = props.size | default('medium') -%}
{%- set _textColor = props.textColor | default(null) -%}
{%- set _textAlignment = props.textAlignment | default(null) -%}

{# Class names #}
{%- set _rootClassName = _spiritClassPrefix ~ 'typography-heading-' ~ _size ~ '-' ~ _emphasis -%}
{%- set _rootTextColorClassName = _textColor ? _spiritClassPrefix ~ 'text-' ~ _textColor : null -%}
{%- set _rootTextAlignmentClassName = _textAlignment ? _spiritClassPrefix ~ 'text-' ~ _textAlignment : null -%}

{# Miscellaneous #}
{%- set _styleProps = useStyleProps(props) -%}
{%- set _classNames = [ _rootClassName, _rootTextAlignmentClassName, _rootTextColorClassName, _styleProps.className ] -%}
{%- set _allowedAttributes = [ 'translate' ] -%}

<{{ _elementType }} {{ mainProps(props, _allowedAttributes) }} {{ styleProp(_styleProps) }} {{ classProp(_classNames) }}>
{%- block content %}{% endblock -%}
</{{ _elementType }}>
